{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "RabbitMQ: check (prod)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/bootstrap_rabbitmq.py",
            "args": [
                "--config", "${workspaceFolder}/config.yaml",
                "--env-file", "${workspaceFolder}/.env",
                "--check"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "RabbitMQ: apply (prod)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/bootstrap_rabbitmq.py",
            "args": [
                "--config", "${workspaceFolder}/config.yaml",
                "--env-file", "${workspaceFolder}/.env"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}